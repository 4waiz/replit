# Starkz AI — environment variables
#
# Groq powers the live agent reasoning + multilingual worker alerts.
# Get a free key at https://console.groq.com/keys
#
# EXPO_PUBLIC_ prefix is REQUIRED so the value is available in the app bundle
# (web + native). Copy this file to `.env` and fill in your key:
#
#   cp .env.example .env
#
# Without a key the app still runs end-to-end using the deterministic engine,
# so the demo never breaks — but reasoning text will be templated, not generated.

EXPO_PUBLIC_GROQ_API_KEY=
